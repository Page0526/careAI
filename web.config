<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Next.js Frontend (port 3000) -->
        <rule name="CareAI Frontend" stopProcessing="true">
          <match url="^hackathon(?!/api)(.*)" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="^/hackathon/api" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3000/hackathon{R:1}" />
        </rule>

        <!-- FastAPI Backend API (port 8000) -->
        <rule name="CareAI API" stopProcessing="true">
          <match url="^hackathon/api/(.*)" />
          <action type="Rewrite" url="http://localhost:8000/hackathon/api/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    
    <httpProtocol>
      <customHeaders>
        <add name="X-Powered-By" value="CareAI" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
